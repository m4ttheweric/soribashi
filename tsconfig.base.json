{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": false,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "allowImportingTsExtensions": true,
    "noEmit": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    // Declarations are never emitted in this repo — every package sets
    // `"types": "./src/index.ts"` (consumed as source) and all tsc runs are
    // `--noEmit`. Leaving `declaration: true` only triggered TS2742 nameability
    // checks on inferred types (e.g. the generic `createTheme` return) that can
    // never actually be emitted, so it's disabled. Re-enable alongside a real
    // .d.ts build step if packages ever ship compiled types.
    "declaration": false,
    "sourceMap": true,

    "composite": false
  },
  "exclude": ["node_modules", "dist", "build"]
}
