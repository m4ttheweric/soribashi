{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": [
    "packages/*/src/**/*",
    "packages/*/test/**/*",
    "packages/*/bin/**/*",
    "packages/*/scripts/**/*",
    "apps/*/src/**/*",
    "apps/*/test/**/*",
    "apps/*/tests/**/*",
    "apps/*/scripts/**/*",
    "tests/**/*",
    "playwright.config.ts",
    "vitest.workspace.ts",
    "soribashi.config.ts"
  ],
  "exclude": ["**/node_modules", "**/dist", "**/build"]
}
