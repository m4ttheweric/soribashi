{
  "name": "soribashi",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check .",
    "format": "biome format . --write",
    "codegen": "bun run packages/codegen/bin/soribashi.ts build",
    "codegen:watch": "bun run packages/codegen/bin/soribashi.ts watch",
    "codegen:tenants": "bun run --filter @soribashi/playground codegen:tenants",
    "dev:playground": "bun run --filter @soribashi/playground dev",
    "dev": "bun run codegen && bun run codegen:tenants && bun run dev:playground",
    "build:playground": "bun run --filter @soribashi/playground build"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
